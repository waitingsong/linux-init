#!/bin/sh
set -eo pipefail

fs_name="data/log"
mount_name="/data/log"
log_path="/var/log"

echo ==================== OpenZFS 创建文件系统 ${fs_name} ====================


if [[ -d "/${fs_name}" ]]; then
  echo "Directory exists: /${fs_name}"
  exit 1
fi

zfs create ${fs_name}
zfs set dedup=off atime=off relatime=off xattr=sa compression=zstd logbias=throughput recordsize=128K ${fs_name}

zfs_opts='name,used,available,referenced,mountpoint,compression,compressratio,recordsize,logbias,sync,primarycache,readonly,mounted,creation,'
zfs list -o "${zfs_opts}"
zfs-set-quota ${fs_name} 20  # 20% of the pool

